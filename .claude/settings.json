{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash .claude/bump-version.sh",
            "timeout": 10,
            "statusMessage": "Bumping APP_VERSION..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sed -i \"s/Last updated: .*/Last updated: $(date '+%Y-%m-%d')/\" /home/rakesh/Dev/myprojects/mymarkdown/.claude/PROGRESS.md"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Where you left off ===' && grep -A2 '## Current Focus' /home/rakesh/Dev/myprojects/mymarkdown/.claude/PROGRESS.md && echo '' && grep -A4 '## Resume Here' /home/rakesh/Dev/myprojects/mymarkdown/.claude/PROGRESS.md"
          }
        ]
      }
    ]
  }
}
