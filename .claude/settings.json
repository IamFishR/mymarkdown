{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "bash .claude/bump-version.sh",
            "timeout": 10,
            "statusMessage": "Bumping APP_VERSION..."
          }
        ]
      }
    ]
  }
}
